# .env.example

# ---------------------------------------------------------------------------
# Postgres
# ---------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=airflow

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW_UID=50000

# Stable secret key — prevents session invalidation on webserver restart.
# Generate once with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=replace_with_a_random_32_byte_hex_string

AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=change_me

# Optional: override the default webserver port
# AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080

# ---------------------------------------------------------------------------
# Bronze zone
# Must point to the host path mounted as /opt/data in docker-compose.override.yml
# ---------------------------------------------------------------------------
BRONZE_DIR=/opt/data/bronze

# ---------------------------------------------------------------------------
# Ember Energy API
# ---------------------------------------------------------------------------
EMBER_API_KEY=your_ember_api_key_here
